{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "asNeeded"
    }
  },
  "files": {
    "includes": [
      "src/**",
      "*.ts",
      "*.json",
      "!!**/dist",
      "!!**/coverage",
      "!!**/node_modules"
    ]
  }
}
