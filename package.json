{
  "name": "ink-boilerplate",
  "version": "1.0.0",
  "description": "Ink Project Boilerplate",
  "type": "module",
  "author": "Muhammad Rivki <muhammad.rivki@live.com>",
  "main": "dist/index.js",
  "bin": {
    "inkboilerplate": "dist/bin.js"
  },
  "homepage": "https://github.com/mikqi/ink-boilerplate",
  "bugs": {
    "url": "https://github.com/mikqi/ink-boilerplate/issues"
  },
  "keywords": [
    "boilerplate",
    "ink",
    "cli"
  ],
  "scripts": {
    "build": "tsc -d",
    "dev": "ts-node --esm --files src/bin.ts",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --config .eslintrc.cjs --max-warnings=0 --fix",
    "prepare": "git config --local core.hooksPath .git/hooks && simple-git-hooks",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "pretest": "pnpm run build",
    "lint": "eslint . --ext .ts,.tsx,.js --config .eslintrc.cjs --max-warnings=0",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "meow": "^13.2.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/ink-testing-library": "1.0.4",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "ink-testing-library": "^4.0.0",
    "jest": "^30.3.0",
    "jest-serializer-ansi": "^1.0.3",
    "prettier": "^3.8.2",
    "simple-git-hooks": "2.13.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:fix"
  },
  "license": "MIT"
}
