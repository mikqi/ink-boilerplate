{
  "name": "ink-boilerplate",
  "version": "1.0.0",
  "description": "Ink Project Boilerplate",
  "type": "module",
  "author": "Muhammad Rivki <muhammad.rivki@live.com>",
  "main": "dist/index.js",
  "bin": {
    "inkboilerplate": "dist/bin.js"
  },
  "homepage": "https://github.com/mikqi/ink-boilerplate",
  "bugs": {
    "url": "https://github.com/mikqi/ink-boilerplate/issues"
  },
  "keywords": [
    "boilerplate",
    "ink",
    "cli"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "simple-git-hooks",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "meow": "^13.2.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/ink-testing-library": "1.0.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "^4.1.4",
    "ink-testing-library": "^4.0.0",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run check"
  },
  "license": "MIT"
}
